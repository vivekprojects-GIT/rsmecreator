# LLM Provider: ollama (local), openai, google
LLM_PROVIDER=ollama
LLM_MODEL=gpt-oss:120b-cloud

# Embeddings (for future RAG/semantic features)
EMBEDDING_MODEL=nomic-embed-text

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true

# For OpenAI (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# For Google (when LLM_PROVIDER=google)
# GOOGLE_API_KEY=...
